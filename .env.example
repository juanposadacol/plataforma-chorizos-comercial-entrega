VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_PUBLIC_ANON_KEY
VITE_APP_URL=http://localhost:5173
VITE_ENABLE_DEMO_DATA=false

# Solo para scripts administrativos locales. Nunca use VITE_ ni lo exponga al navegador.
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVER_ONLY_SERVICE_ROLE_KEY
SUPABASE_ACCESS_TOKEN=YOUR_LOCAL_CLI_ACCESS_TOKEN

# Secretos para `supabase secrets set`; no se usan desde Vite.
WHATSAPP_ACCESS_TOKEN=YOUR_META_SERVER_TOKEN
WHATSAPP_PHONE_NUMBER_ID=YOUR_META_PHONE_NUMBER_ID
WHATSAPP_ADMIN_NUMBER=573001234567
WHATSAPP_TEMPLATE_NAME=nuevo_pedido
ADMIN_PANEL_URL=https://YOUR_SITE.netlify.app/admin/pedidos
